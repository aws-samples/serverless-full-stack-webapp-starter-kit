{
  "name": "@repo/cdk",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test:unit": "vitest run",
    "format": "oxfmt --write .",
    "format:ci": "oxfmt --check .",
    "lint": "oxlint --config ../../oxlintrc.json --fix .",
    "lint:ci": "oxlint --config ../../oxlintrc.json --max-warnings 0 .",
    "check": "pnpm run lint && pnpm run format",
    "check:ci": "pnpm run lint:ci && pnpm run format:ci",
    "cdk": "cdk"
  },
  "dependencies": {
    "@aws-appsync/utils": "^2.1.1",
    "@aws-sdk/client-cognito-identity-provider": "^3.1093.0",
    "@cdklabs/deploy-time-build": "^0.1.6",
    "@repo/shared-types": "workspace:*",
    "aws-cdk-lib": "^2.262.0",
    "cdk-nag": "^2.14.29",
    "constructs": "^10.7.1",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.162",
    "@types/node": "^26",
    "aws-cdk": "^2.1132.1",
    "esbuild": "^0.28.1",
    "ts-node": "^10.7.0",
    "typescript": "^5.9.2",
    "vitest": "^4"
  }
}
