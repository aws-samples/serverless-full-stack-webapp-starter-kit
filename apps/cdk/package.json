{
  "name": "@repo/cdk",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test:unit": "jest",
    "format": "oxfmt --write .",
    "format:ci": "oxfmt --check .",
    "lint": "oxlint --config ../../oxlintrc.json --fix --ignore-pattern lib/constructs/dsql-migrator/handler.ts .",
    "lint:ci": "oxlint --config ../../oxlintrc.json --max-warnings 0 --ignore-pattern lib/constructs/dsql-migrator/handler.ts .",
    "check": "pnpm run lint && pnpm run format",
    "check:ci": "pnpm run lint:ci && pnpm run format:ci",
    "cdk": "cdk"
  },
  "dependencies": {
    "@aws-appsync/utils": "^1.12.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.987.0",
    "@cdklabs/deploy-time-build": "^0.1.1",
    "@types/aws-lambda": "^8.10.149",
    "aws-cdk-lib": "^2.189.1",
    "cdk-nag": "^2.14.29",
    "constructs": "^10.0.0",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@types/jest": "^27.5.0",
    "@types/node": "^22.14.1",
    "aws-cdk": "^2.1007.0",
    "esbuild": "^0.25.4",
    "jest": "^30.1.3",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.7.0",
    "typescript": "^5.9.2"
  }
}
